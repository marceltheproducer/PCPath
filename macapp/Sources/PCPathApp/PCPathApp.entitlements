<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Finder Sync host app must be sandboxed (the extension requires it). -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <!-- Let the app read AND write the shared mappings file in the user's home,
         preserving the cross-tool ~/.pcpath_mappings convention. Notarizable
         for Developer ID distribution. -->
    <key>com.apple.security.temporary-exception.files.home-relative-path.read-write</key>
    <array>
        <string>/.pcpath_mappings</string>
    </array>
</dict>
</plist>
