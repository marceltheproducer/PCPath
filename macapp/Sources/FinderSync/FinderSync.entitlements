<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required: Finder only loads sandboxed Finder Sync extensions. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <!-- Read-only access to the shared mappings file in the user's home so the
         extension can load drive-letter mappings + STRIP rules. -->
    <key>com.apple.security.temporary-exception.files.home-relative-path.read-only</key>
    <array>
        <string>/.pcpath_mappings</string>
    </array>
</dict>
</plist>
